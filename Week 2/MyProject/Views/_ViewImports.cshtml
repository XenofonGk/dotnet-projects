@* 
    The '@using' directive makes namespaces available globally to all Razor views. 
    This allows you to reference models directly without their full namespace.
*@
@using MyProject
@using MyProject.Models

@* 
    '@addTagHelper' enables ASP.NET Core Tag Helpers (like 'asp-controller', 'asp-action') 
    across all views, making HTML easier to write and more dynamic.
*@
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
